# Copy to .env.production on the server and replace secrets before starting.

POSTGRES_HOST_PORT=15432
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:15432/buscachat_dev

# OpenTelemetry / Honeycomb
# OTEL_SERVICE_NAME becomes the Honeycomb Service Dataset name.
OTEL_SERVICE_NAME=buscachat-python
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=change-me
OTEL_PYTHON_LOGGING_AUTO_INSTRUMENTATION_ENABLED=true

REDIS_HOST_PORT=6379
REDIS_PASSWORD=change-me
REDIS_URL=redis://:change-me@localhost:6379/0
REDIS_KEY_PREFIX=buscachat:conversation:
CONVERSATION_STATE_STORE=redis
CONVERSATION_STATE_TTL_SECONDS=0

BOT_SOURCE=whatsapp_bot

# Keep production dependency-light unless the server is prepared with:
# uv sync --frozen --no-dev --group face
FACE_MATCHER=stub
FACE_MATCH_THRESHOLD=0.35
FACE_INSIGHTFACE_MODEL=buffalo_l

IMAGE_DOWNLOAD_TIMEOUT_SECONDS=30

# Meta WhatsApp Cloud API
META_GRAPH_API_VERSION=v25.0
META_VERIFY_TOKEN=change-me
META_APP_SECRET=change-me
META_ACCESS_TOKEN=change-me
META_PHONE_NUMBER_ID=change-me
